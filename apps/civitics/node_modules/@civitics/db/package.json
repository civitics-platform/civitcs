{
  "name": "@civitics/db",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:migrate": "supabase db push",
    "db:types": "supabase gen types typescript --local > src/types/database.ts"
  },
  "devDependencies": {
    "@civitics/config": "workspace:*",
    "typescript": "^5.4.0",
    "supabase": "^1.175.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.0"
  }
}
