# Supabase (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-only — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Mapbox (browser-safe — public token is OK, scope to your domain in Mapbox dashboard)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token

# Claude API (server-only)
ANTHROPIC_API_KEY=sk-ant-your-key

# Cloudflare R2 (server-only)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=civitics-documents

# Privy (Phase 4 — leave blank for Phase 0)
NEXT_PUBLIC_PRIVY_APP_ID=
